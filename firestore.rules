
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function estaLogado() {
      return request.auth != null;
    }

    function uidAtual() {
      return request.auth.uid;
    }

    function ehDono(userId) {
      return estaLogado() && uidAtual() == userId;
    }

    function ehAdmin() {
      return estaLogado() && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) && (
             get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.isAdmin == true ||
             get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin' ||
             get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.tipo == 'admin');
    }

    function participaDoDocumentoFinanceiro(data) {
      return estaLogado() && data != null && (
        data.clienteId == uidAtual() ||
        data.profissionalId == uidAtual() ||
        data.clinicaId == uidAtual() ||
        data.colaboradorId == uidAtual() ||
        data.usuarioId == uidAtual() ||
        data.ownerId == uidAtual() ||
        data.userId == uidAtual() ||
        ehAdmin()
      );
    }

    match /usuarios/{userId} {
      allow read: if estaLogado();
      allow create: if estaLogado();
      allow update: if ehDono(userId) || ehAdmin();
      allow delete: if false;

      match /notificacoes/{notificacaoId} {
        allow read: if ehDono(userId);
        allow create: if estaLogado();
        allow update: if ehDono(userId);
        allow delete: if ehDono(userId);
      }

      match /favoritos/{favoritoId} {
        allow read, write: if ehDono(userId);
      }

      match /servicos/{servicoId} {
        allow read: if request.auth != null;
        allow write: if ehDono(userId) || ehAdmin();
      }

      match /configuracoes/{configId} {
        allow read: if ehDono(userId) || (estaLogado() && configId == "agenda");
        allow write: if ehDono(userId);
      }

      match /colaboradores/{colabId} {
        allow read: if estaLogado();
        allow write: if ehDono(userId);

        match /configuracoes/{configId} {
          allow read: if ehDono(userId) || (estaLogado() && configId == "agenda");
          allow write: if ehDono(userId);
        }
      }

      match /avaliacoes/{avaliacaoId} {
        allow read: if true;
        allow create: if estaLogado();
        allow update: if ehDono(userId);
        allow delete: if ehDono(userId);
      }

      match /menores/{menorId} {
        allow read, write: if ehDono(userId);
      }
    }

    // ✅ CORREÇÃO 2: Avaliações na coleção raiz
    // AvaliarAtendimento.js grava em /avaliacoes/{id} (raiz), não em subcoleção.
    // Sem esta regra, a leitura caía no bloqueio geral e gerava o erro de permissão.
    match /avaliacoes/{avaliacaoId} {
      allow read: if true;
      allow create: if estaLogado();
      allow update: if estaLogado() && resource.data.clienteId == uidAtual();
      allow delete: if false;
    }

    match /categorias/{categoriaId} {
      allow read: if true;
      allow create: if estaLogado();
      allow update, delete: if ehAdmin();
    }

    match /agendamentos/{agendamentoId} {
      // Permitir leitura se usuário autenticado (a query já filtra por clinicaId/profissionalId)
      allow read: if estaLogado();
      allow create: if estaLogado();
      allow update: if estaLogado() && participaDoDocumentoFinanceiro(resource.data);
      allow delete: if false;
    }

     // NOVAS COLEÇÕES - Planos e Contratos Recorrentes
    match /planosRecorrentes/{planoId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        resource.data.profissionalId == request.auth.uid;
    }

    match /contratosRecorrentes/{contratoId} {
      // Permitir leitura para usuários autenticados - a query filtra por profissionalId ou clienteId
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Para update/delete, verificar se é profissional ou cliente do contrato
      allow update: if request.auth != null && (
        (resource.data.profissionalId == request.auth.uid || resource.data.clienteId == request.auth.uid) ||
        (request.resource.data.profissionalId == request.auth.uid || request.resource.data.clienteId == request.auth.uid)
      );
      allow delete: if request.auth != null && (
        resource.data.profissionalId == request.auth.uid ||
        resource.data.clienteId == request.auth.uid
      );
    }

    // ✅ CORREÇÃO 1: Pagamentos — permite leitura quando documento ainda não existe.
    // buscarCobrancaPorAgendamento() faz getDoc antes de criar a cobrança.
    // A regra anterior bloqueava porque resource.data era null (doc inexistente).
    match /pagamentos/{pagamentoId} {
      allow read: if estaLogado() && (
        !exists(/databases/$(database)/documents/pagamentos/$(pagamentoId)) ||
        participaDoDocumentoFinanceiro(resource.data)
      );
      allow create: if estaLogado();
      allow update: if estaLogado() && (
        participaDoDocumentoFinanceiro(resource.data) ||
        participaDoDocumentoFinanceiro(request.resource.data)
      );
      allow delete: if false;
    }

    match /cobrancas/{cobrancaId} {
      allow read: if participaDoDocumentoFinanceiro(resource.data);
      allow create: if estaLogado();
      allow update: if
        participaDoDocumentoFinanceiro(resource.data) ||
        participaDoDocumentoFinanceiro(request.resource.data);
      allow delete: if false;
    }

    match /saques/{saqueId} {
      allow read: if participaDoDocumentoFinanceiro(resource.data);
      allow create: if estaLogado();
      allow update: if participaDoDocumentoFinanceiro(resource.data) || ehAdmin();
      allow delete: if false;
    }

    match /saldos/{saldoId} {
      allow read: if estaLogado();
      allow create: if estaLogado();
      allow update: if
        ehDono(saldoId) ||
        participaDoDocumentoFinanceiro(resource.data) ||
        participaDoDocumentoFinanceiro(request.resource.data) ||
        ehAdmin();
      allow delete: if false;
    }

    // SUPORTE — Regras para tickets e mensagens
    match /suporte/{ticketId} {
      // O usuário pode ler/escrever se o ticketId for o UID dele (estilo antigo)
      // OU se o campo usuarioId for igual ao UID dele (estilo novo)
      allow read: if estaLogado() && (ticketId == uidAtual() || resource.data.usuarioId == uidAtual() || ehAdmin());
      allow create: if estaLogado() && (ticketId == uidAtual() || request.resource.data.usuarioId == uidAtual());
      allow update: if estaLogado() && (ticketId == uidAtual() || resource.data.usuarioId == uidAtual() || ehAdmin());
      allow delete: if ehAdmin();

      match /mensagens/{msgId} {
        allow read, write: if estaLogado() && (ticketId == uidAtual() || get(/databases/$(database)/documents/suporte/$(ticketId)).data.usuarioId == uidAtual() || ehAdmin());
      }
    }

    match /agenda_ocupada/{slotId} {
      allow read: if estaLogado();
      allow create: if estaLogado();
      allow delete: if estaLogado();
      allow update: if false;
    }

    // Transações financeiras — usada pela página Financeiro (web/desktop)
    // Leitura: autenticado (a query filtra por profissionalId)
    // Escrita: só o profissional dono da transação
    match /transacoes/{transacaoId} {
      allow read: if estaLogado();
      allow create: if estaLogado()
        && request.resource.data.profissionalId == uidAtual();
      allow update, delete: if estaLogado()
        && resource.data.profissionalId == uidAtual();
    }

    // Colaboradores (coleção raiz) — usada pela versão web/desktop
    // A versão mobile usa subcoleção /usuarios/{id}/colaboradores (regra já existe acima)
    match /colaboradores/{colabId} {
      // Leitura: qualquer autenticado (a query já filtra por profissionalId)
      allow read: if estaLogado();

      // Criação: só se o profissionalId do documento for o próprio usuário
      allow create: if estaLogado()
        && request.resource.data.profissionalId == uidAtual();

      // Edição e exclusão: só o profissional dono do colaborador
      allow update, delete: if estaLogado()
        && resource.data.profissionalId == uidAtual();
    }

    // ✅ ASSINATURAS — Coleção para assinaturas VIP (backend Asaas)
    match /assinaturas/{assinaturaId} {
      // Leitura: usuário vê suas próprias assinaturas OU admin vê todas
      allow read: if estaLogado() && (
        resource.data.userId == uidAtual() || ehAdmin()
      );
      // Criação/Update: só backend (webhook) ou admin
      allow create, update: if estaLogado() && (
        request.resource.data.userId == uidAtual() || ehAdmin()
      );
      allow delete: if ehAdmin();
    }

    // ✅ WEBHOOK LOGS — Logs de comunicação com Asaas (debug/monitoramento)
    match /webhookLogs/{logId} {
      // Leitura: apenas admin pode ver logs de webhooks
      allow read: if ehAdmin();
      // Criação: backend pode criar logs
      allow create: if estaLogado();
      allow update, delete: if ehAdmin();
    }

    // ✅ ACTIVITY LOGS — Logs de atividades dos usuários (monitoramento em tempo real)
    match /activityLogs/{logId} {
      // Leitura: admin pode ler TUDO; usuário comum pode ler apenas SEUS logs
      allow read: if ehAdmin() || (estaLogado() && resource.data.userId == uidAtual());
      // Criação: qualquer usuário logado pode criar log (o app garante que é do próprio user)
      allow create: if estaLogado();
      // Update/Delete: apenas admin
      allow update, delete: if ehAdmin();
    }

    // ✅ CAMPANHAS — Campanhas de marketing (apenas admin)
    match /campanhas/{campanhaId} {
      allow read: if ehAdmin();
      allow create: if ehAdmin();
      allow update: if ehAdmin();
      allow delete: if ehAdmin();
    }

    // ✅ EQUIPE ADMIN — Gestão de equipe administrativa (apenas admin)
    match /equipeAdmin/{membroId} {
      allow read: if ehAdmin();
      allow create: if ehAdmin();
      allow update: if ehAdmin();
      allow delete: if ehAdmin();
    }

    // ✅ ANUNCIOS — Sistema de anúncios patrocinados
    match /anuncios/{anuncioId} {
      // Admin gerencia tudo
      allow read: if ehAdmin() || (
        estaLogado() && 
        resource.data.status == 'ativo' && 
        resource.data.dataInicio <= request.time &&
        resource.data.dataFim >= request.time
      );
      allow create: if ehAdmin();
      allow update: if ehAdmin() || (
        estaLogado() && 
        resource.data.anuncianteId == uidAtual()
      );
      allow delete: if ehAdmin();
    }

    // ✅ ANUNCIANTES — Empresas anunciantes
    match /anunciantes/{anuncianteId} {
      allow read: if ehAdmin() || (
        estaLogado() && anuncianteId == uidAtual()
      );
      allow create: if estaLogado(); // Qualquer um pode se cadastrar
      allow update: if ehAdmin() || (
        estaLogado() && anuncianteId == uidAtual()
      );
      allow delete: if ehAdmin();
    }

    // ✅ IMPRESSOES ANUNCIOS — Tracking (qualquer usuário logado pode registrar)
    match /impressoesAnuncios/{impressaoId} {
      allow read: if ehAdmin();
      allow create: if estaLogado();
      allow update, delete: if false;
    }

    // ✅ CLIQUES ANUNCIOS — Tracking (qualquer usuário logado pode registrar)
    match /cliquesAnuncios/{cliqueId} {
      allow read: if ehAdmin();
      allow create: if estaLogado();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
