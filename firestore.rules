
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function estaLogado() {
      return request.auth != null;
    }

    function uidAtual() {
      return request.auth.uid;
    }

    function ehDono(userId) {
      return estaLogado() && uidAtual() == userId;
    }

    function ehAdmin() {
      return estaLogado() && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.isAdmin == true;
    }

    function participaDoDocumentoFinanceiro(data) {
      return estaLogado() && data != null && (
        data.clienteId == uidAtual() ||
        data.profissionalId == uidAtual() ||
        data.clinicaId == uidAtual() ||
        data.colaboradorId == uidAtual() ||
        data.usuarioId == uidAtual() ||
        data.ownerId == uidAtual() ||
        data.userId == uidAtual() ||
        ehAdmin()
      );
    }

    match /usuarios/{userId} {
      allow read: if estaLogado();
      allow create: if estaLogado();
      allow update: if ehDono(userId) || ehAdmin();
      allow delete: if false;

      match /notificacoes/{notificacaoId} {
        allow read: if ehDono(userId);
        allow create: if estaLogado();
        allow update: if ehDono(userId);
        allow delete: if ehDono(userId);
      }

      match /favoritos/{favoritoId} {
        allow read, write: if ehDono(userId);
      }

      match /servicos/{servicoId} {
        allow read: if estaLogado();
        allow write: if ehDono(userId);
      }

      match /configuracoes/{configId} {
        allow read: if ehDono(userId) || (estaLogado() && configId == "agenda");
        allow write: if ehDono(userId);
      }

      match /colaboradores/{colabId} {
        allow read: if estaLogado();
        allow write: if ehDono(userId);

        match /configuracoes/{configId} {
          allow read: if ehDono(userId) || (estaLogado() && configId == "agenda");
          allow write: if ehDono(userId);
        }
      }

      match /avaliacoes/{avaliacaoId} {
        allow read: if true;
        allow create: if estaLogado();
        allow update: if ehDono(userId);
        allow delete: if ehDono(userId);
      }

      match /menores/{menorId} {
        allow read, write: if ehDono(userId);
      }
    }

    // ✅ CORREÇÃO 2: Avaliações na coleção raiz
    // AvaliarAtendimento.js grava em /avaliacoes/{id} (raiz), não em subcoleção.
    // Sem esta regra, a leitura caía no bloqueio geral e gerava o erro de permissão.
    match /avaliacoes/{avaliacaoId} {
      allow read: if true;
      allow create: if estaLogado();
      allow update: if estaLogado() && resource.data.clienteId == uidAtual();
      allow delete: if false;
    }

    match /categorias/{categoriaId} {
      allow read: if true;
      allow write: if ehAdmin();
    }

    match /agendamentos/{agendamentoId} {
      // Permitir leitura se usuário autenticado (a query já filtra por clinicaId/profissionalId)
      allow read: if estaLogado();
      allow create: if estaLogado();
      allow update: if estaLogado() && participaDoDocumentoFinanceiro(resource.data);
      allow delete: if false;
    }

     // NOVAS COLEÇÕES - Planos e Contratos Recorrentes
    match /planosRecorrentes/{planoId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        resource.data.profissionalId == request.auth.uid;
    }

    match /contratosRecorrentes/{contratoId} {
      // Permitir leitura para usuários autenticados - a query filtra por profissionalId ou clienteId
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Para update/delete, verificar se é profissional ou cliente do contrato
      allow update: if request.auth != null && (
        (resource.data.profissionalId == request.auth.uid || resource.data.clienteId == request.auth.uid) ||
        (request.resource.data.profissionalId == request.auth.uid || request.resource.data.clienteId == request.auth.uid)
      );
      allow delete: if request.auth != null && (
        resource.data.profissionalId == request.auth.uid ||
        resource.data.clienteId == request.auth.uid
      );
    }

    // ✅ CORREÇÃO 1: Pagamentos — permite leitura quando documento ainda não existe.
    // buscarCobrancaPorAgendamento() faz getDoc antes de criar a cobrança.
    // A regra anterior bloqueava porque resource.data era null (doc inexistente).
    match /pagamentos/{pagamentoId} {
      allow read: if estaLogado() && (
        !exists(/databases/$(database)/documents/pagamentos/$(pagamentoId)) ||
        participaDoDocumentoFinanceiro(resource.data)
      );
      allow create: if estaLogado();
      allow update: if estaLogado() && (
        participaDoDocumentoFinanceiro(resource.data) ||
        participaDoDocumentoFinanceiro(request.resource.data)
      );
      allow delete: if false;
    }

    match /cobrancas/{cobrancaId} {
      allow read: if participaDoDocumentoFinanceiro(resource.data);
      allow create: if estaLogado();
      allow update: if
        participaDoDocumentoFinanceiro(resource.data) ||
        participaDoDocumentoFinanceiro(request.resource.data);
      allow delete: if false;
    }

    match /saques/{saqueId} {
      allow read: if participaDoDocumentoFinanceiro(resource.data);
      allow create: if estaLogado();
      allow update: if participaDoDocumentoFinanceiro(resource.data) || ehAdmin();
      allow delete: if false;
    }

    match /saldos/{saldoId} {
      allow read: if estaLogado();
      allow create: if estaLogado();
      allow update: if
        ehDono(saldoId) ||
        participaDoDocumentoFinanceiro(resource.data) ||
        participaDoDocumentoFinanceiro(request.resource.data) ||
        ehAdmin();
      allow delete: if false;
    }

    match /suporte/{userId} {
      allow read, write: if estaLogado() && (request.auth.uid == userId || ehAdmin());
      
      match /mensagens/{msgId} {
        allow read, write: if estaLogado() && (request.auth.uid == userId || ehAdmin());
      }
    }

    match /agenda_ocupada/{slotId} {
      allow read: if estaLogado();
      allow create: if estaLogado();
      allow delete: if estaLogado();
      allow update: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
