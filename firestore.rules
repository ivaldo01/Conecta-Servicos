rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function estaLogado() {
      return request.auth != null;
    }

    function ehDono(userId) {
      return estaLogado() && request.auth.uid == userId;
    }

    function ehProfissional(resourceData) {
      return resourceData.tipo == "profissional" || resourceData.perfil == "profissional";
    }

    function podeLerPerfilProfissional() {
      return estaLogado() && ehProfissional(resource.data);
    }

    match /usuarios/{userId} {

      // Dono pode ler e editar seu próprio documento
      allow read, write: if ehDono(userId);

      // Outros usuários autenticados podem ler perfis profissionais
      allow read: if podeLerPerfilProfissional();

      match /notificacoes/{notificacaoId} {
        allow read: if ehDono(userId);
        allow create: if estaLogado();
        allow update, delete: if ehDono(userId);
      }

      match /favoritos/{favoritoId} {
        allow read, write: if ehDono(userId);
      }

      match /servicos/{servicoId} {
        allow read: if estaLogado();
        allow write: if ehDono(userId);
      }

      match /configuracoes/{configId} {
        // Dono tem acesso total
        allow read, write: if ehDono(userId);

        // Usuários autenticados podem ler agenda pública do profissional
        allow read: if estaLogado() && configId == "agenda";
      }

      match /colaboradores/{colabId} {
        allow read: if estaLogado();
        allow write: if ehDono(userId);

        match /configuracoes/{configId} {
          // Dono pode tudo
          allow read, write: if ehDono(userId);

          // Usuários autenticados podem ler agenda do colaborador
          allow read: if estaLogado() && configId == "agenda";
        }
      }

      match /menores/{menorId} {
        allow read, write: if ehDono(userId);
      }
    }

    match /categorias/{categoriaId} {
      allow read: if true;
      allow write: if estaLogado();
    }

    match /agendamentos/{agendamentoId} {
      allow create: if estaLogado();

      // TEMPORÁRIO / funcional para o fluxo de disponibilidade:
      // usuários autenticados podem ler agendamentos
      allow read: if estaLogado();

      allow update: if estaLogado() && (
        resource.data.clienteId == request.auth.uid ||
        resource.data.clinicaId == request.auth.uid ||
        resource.data.colaboradorId == request.auth.uid
      );

      allow delete: if false;
    }

    match /avaliacoes/{avaliacaoId} {
      allow read: if true;
      allow create: if estaLogado();
      allow update: if false;
      allow delete: if false;
    }
  }
}